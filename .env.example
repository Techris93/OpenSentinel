# Google Gemini API (https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# VirusTotal API (https://www.virustotal.com/gui/join-us)
VIRUSTOTAL_API_KEY=your_virustotal_api_key_here

# AbuseIPDB API (https://www.abuseipdb.com/register)
ABUSEIPDB_API_KEY=your_abuseipdb_api_key_here

# Splunk Connection (optional — can also be set via /api/connect)
SPLUNK_HOST=localhost
SPLUNK_PORT=8089
SPLUNK_USERNAME=admin
SPLUNK_PASSWORD=changeme

# Security Configuration
OPENSENTINEL_API_KEY=your-secure-api-key-here
RATE_LIMIT=60
RATE_WINDOW=60
CORS_ORIGINS=http://localhost:5001
ENABLE_SECURITY_HEADERS=true

# Server
PORT=5001
